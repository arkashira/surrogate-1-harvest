[Unit]
Description=axentx TRACK C — trend arbitrage analyzer (LLM Thai-market-fit scorer)
After=network-online.target axentx-global-trend-harvester-daemon.service
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/surrogate-1-harvest
EnvironmentFile=/etc/surrogate-coordinator.env
Environment=PYTHONUNBUFFERED=1
Environment=REPO_ROOT=/opt/surrogate-1-harvest
ExecStart=/opt/surrogate-1-harvest/.venv/bin/python /opt/surrogate-1-harvest/bin/axentx-trend-arbitrage-daemon.py
Restart=always
RestartSec=15
MemoryMax=256M
CPUQuota=25%

[Install]
WantedBy=multi-user.target
